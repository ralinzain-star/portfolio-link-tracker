# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your default portfolio URL
NEXT_PUBLIC_DEFAULT_PORTFOLIO_URL=https://your-portfolio.com

# The public base URL of this app (for generating links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# (Optional) Resend — email notification
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_EMAIL=you@example.com

# Daily report cron — set in Vercel env vars; add locally for curl testing
CRON_SECRET=your-secret-here
